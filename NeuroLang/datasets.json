        "default_args": {"root": "./data", "train": true, "download": true}
    },
    "CIFAR100": {
        "pytorch_class": "torchvision.datasets.CIFAR100",
        "default_args": {"root": "./data", "train": true, "download": true}
    },
    "SVHN": {
        "pytorch_class": "torchvision.datasets.SVHN",
